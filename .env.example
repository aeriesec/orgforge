# .env.example
# Copy this file to .env and fill in your values.

# config/config.yaml controls the active model preset.
# Current default: quality_preset: "openai_labelbox"
QUALITY_PRESET=openai_labelbox

# ── LOCAL OLLAMA ROUTING ──────────────────────────────────────────
# If running Ollama directly on your host machine (Mac/Windows Desktop),
# host.docker.internal allows the Docker container to reach it.
# On Linux without Docker Desktop, you may need your actual local IP.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── OPENAI VIA LABELBOX ───────────────────────────────────────────
# Required if quality_preset is set to "openai_labelbox" in config.yaml.
# All agent LLM calls and embeddings route through this OpenAI-compatible
# Labelbox gateway when the openai_labelbox preset is active.
OPENAI_LABELBOX_API_KEY=your_labelbox_api_key_here
OPENAI_LABELBOX_BASE_URL=https://models.labelbox.com/api/v1/models/litellm/v1
OPENAI_LABELBOX_DEFAULT_HEADERS='{"x-labelbox-context":"{\"tag\":\"foundry_litellm_test_openai\",\"project_id\":\"test_cuid\"}"}'

# ── CLOUD PRESET CREDENTIALS ──────────────────────────────────────
# Only required if quality_preset is set to "cloud" in config.yaml.
# INSTALL_CLOUD_DEPS=true

# OpenAI (Used for embeddings: text-embedding-3-large)
# OPENAI_API_KEY=your_openai_api_key_here

# AWS Bedrock (Used for Claude 3.5 Sonnet and Llama 3.1)
# AWS_ACCESS_KEY_ID=your_aws_access_key_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
# AWS_DEFAULT_REGION=us-east-1
# AWS_SESSION_TOKEN=  # Uncomment if using temporary STS credentials

# ── ADVANCED CONFIGURATION (Optional) ─────────────────────────────
# Override these if you are bringing your own database or using custom models.
# If left blank, the system defaults to the local Docker setups.

# Custom MongoDB Connection (e.g., external Atlas cluster or local host)
# MONGO_URI=mongodb://your-custom-db-host:27017/?directConnection=true

# Custom Embedding Settings (Must match your config.yaml quality preset)
EMBED_PROVIDER=openai_labelbox
EMBED_MODEL=openai/text-embedding-3-large
EMBED_DIMS=1024

# Dataset viewer
VIEWER_PORT=8765
# VIEWER_DB_NAME=orgforge
# ORGFORGE_EXPORT_DIR=/app/export
